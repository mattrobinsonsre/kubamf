{
  "name": "kubamf-web",
  "version": "0.0.0",
  "description": "Kubernetes GUI - Web and Electron version of kubamf",
  "main": "src/electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "nodemon src/backend/server.js",
    "prebuild": "node scripts/generate-icon.js && node scripts/generate-docs.js",
    "build": "npm run build:frontend && npm run build:backend",
    "generate-docs": "node scripts/generate-docs.js",
    "build:frontend": "vite build",
    "build:frontend:static": "VITE_STATIC_HOSTING=true vite build",
    "build:backend": "ncc build src/backend/server.js -o dist/backend",
    "preelectron": "node scripts/generate-icon.js",
    "electron": "concurrently \"npm run dev:backend\" \"wait-on http://localhost:5173 && electron .\"",
    "preelectron:build": "node scripts/generate-icon.js",
    "electron:build": "npm run build && electron-builder",
    "preelectron:pack": "node scripts/generate-icon.js",
    "electron:pack": "npm run build && electron-builder --dir",
    "web:start": "npm run build && node dist/backend/index.js",
    "web:dev": "npm run dev",
    "preview": "vite preview",
    "test": "node scripts/test-parallel.js",
    "test:parallel": "node scripts/test-parallel.js",
    "test:sequential": "npm run test:backend && npm run test:frontend",
    "test:backend": "jest src/backend --testPathPattern=src/backend",
    "test:frontend": "vitest run src/",
    "test:watch": "concurrently \"npm run test:backend:watch\" \"npm run test:frontend:watch\"",
    "test:backend:watch": "jest src/backend --watch",
    "test:frontend:watch": "vitest src/frontend",
    "test:coverage": "npm run test:backend:coverage && npm run test:frontend:coverage",
    "test:backend:coverage": "jest src/backend --coverage",
    "test:frontend:coverage": "vitest run src/frontend --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "kubernetes",
    "kubectl",
    "gui",
    "electron",
    "web"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@playwright/test": "^1.39.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20.8.0",
    "@vercel/ncc": "^0.36.1",
    "@vitejs/plugin-react": "^4.0.3",
    "@vitest/coverage-v8": "^0.34.6",
    "concurrently": "^8.2.0",
    "electron": "^26.0.0",
    "electron-builder": "^24.6.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jsdom": "^22.1.0",
    "marked": "^16.3.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1",
    "vite": "^4.4.5",
    "vitest": "^0.34.6",
    "wait-on": "^7.0.1"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.2",
    "@kubernetes/client-node": "^0.20.0",
    "@tanstack/react-query": "^4.32.6",
    "@uiw/codemirror-theme-vscode": "^4.25.2",
    "@uiw/react-codemirror": "^4.25.2",
    "@xterm/addon-attach": "^0.11.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.15",
    "axios": "^1.5.0",
    "clsx": "^2.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "lucide-react": "^0.279.0",
    "morgan": "^1.10.0",
    "passport-local": "^1.0.0",
    "postcss": "^8.4.29",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.3",
    "ws": "^8.18.3",
    "yaml": "^2.3.2"
  },
  "build": {
    "appId": "com.kubamf.app",
    "productName": "Kubamf",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "src/electron/main.js",
      "src/electron/preload.js",
      "src/backend/ipc-handlers.js",
      "src/shared/**/*",
      "package.json"
    ],
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        },
        {
          "target": "zip",
          "arch": "universal"
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Development",
      "synopsis": "Kubernetes Resource Management Desktop Application",
      "description": "A modern desktop application for managing Kubernetes resources with a clean, intuitive interface.",
      "maintainer": "Kubamf Team <support@kubamf.com>",
      "vendor": "Kubamf"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libsecret-1-0"
      ],
      "recommends": [
        "kubectl"
      ],
      "priority": "optional"
    },
    "rpm": {
      "depends": [
        "gtk3",
        "libnotify",
        "nss",
        "libXScrnSaver",
        "libXtst",
        "xdg-utils",
        "at-spi2-atk",
        "libsecret"
      ]
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.AppImage",
      "desktop": {
        "Terminal": false,
        "Type": "Application",
        "Categories": "Development;Utility;",
        "StartupWMClass": "kubamf"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
